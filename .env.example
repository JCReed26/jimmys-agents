# ── Required ──────────────────────────────────────────────────────────────────
# Gemini LLM (get from Google AI Studio: https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# TickTick OAuth (get from https://developer.ticktick.com/manage)
TICKTICK_CLIENT_ID=your_ticktick_client_id
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret
TICKTICK_REDIRECT_URI=http://localhost:8080/callback

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
# Sign up at https://smith.langchain.com — enables per-run traces in LangSmith
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=jimmys-agents

# ── Optional: override defaults ───────────────────────────────────────────────
# METRICS_DB_PATH=/app/data/metrics.db  # where SQLite metrics are stored

# ── job-app-chain ─────────────────────────────────────────────────────────────
SHEET_ID=your_google_sheet_id
JOB_SEARCH_TERM=Software Engineer
JOB_LOCATION=Remote
JOB_RESULTS_WANTED=10
JOB_HOURS_OLD=24

# Google Drive IDs for job-app-chain optimizer
# Get file IDs from the URL: docs.google.com/document/d/{FILE_ID}/edit
RESUME_TEMPLATE_DRIVE_ID=
COVER_LETTER_TEMPLATE_DRIVE_ID=
DRIVE_OUTPUT_FOLDER_ID=

# ── Secrets setup (DO NOT put credentials here) ───────────────────────────────
# Place these files in secrets/ (volume-mounted into containers, never committed):
#   secrets/credentials.json       — Google OAuth client credentials
#   secrets/token.json             — Gmail OAuth token (auto-generated on first run)
#   secrets/calendar_token.json    — Google Calendar OAuth token
#   secrets/sheets_token.json      — Google Sheets OAuth token
#   secrets/.token-oauth           — TickTick OAuth token (auto-generated on first run)
#
# Get credentials.json from Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
#   Create → OAuth 2.0 Client ID → Desktop App → Download JSON → rename to credentials.json

# ── Supabase Auth + Postgres ──────────────────────────────────────────────────
# Project: jimmys-agents (us-east-1) | Dashboard: https://supabase.com/dashboard/project/jvtrdsrowhsanjmyymro
SUPABASE_URL=https://jvtrdsrowhsanjmyymro.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard-settings-api
DATABASE_URL=postgresql://postgres:[password]@db.jvtrdsrowhsanjmyymro.supabase.co:5432/postgres

# Supabase (frontend - Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://jvtrdsrowhsanjmyymro.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-from-supabase-dashboard

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API gateway.
# Default (if unset): http://localhost:3000
# Example for production: CORS_ORIGINS=http://localhost:3000,https://agents.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ── Internal agent-to-gateway auth ───────────────────────────────────────────
# Agents posting HOTL logs use this key instead of a JWT. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Leave unset to disable the bypass entirely (fail secure).
INTERNAL_API_KEY=
